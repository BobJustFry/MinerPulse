# Copy to .env (install.sh generates this automatically)

BASE_DOMAIN=mpulse.bob4.fun
LETSENCRYPT_EMAIL=admin@bob4.fun
DEPLOY_MODE=standalone
HTTP_PORT=80
HTTPS_PORT=443
ADMIN_IP_ALLOWLIST=

POSTGRES_USER=mpulse
POSTGRES_PASSWORD=
POSTGRES_DB=mpulse
DATABASE_URL=postgresql://mpulse:CHANGE_ME@postgres:5432/mpulse

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
LICENSE_OFFLINE_GRACE_DAYS=14
BETA_SELF_SERVICE=true
BETA_MAX_DEVICES=10

API_PORT=3001
WEB_PORT=3000
ADMIN_PORT=3002

PUBLIC_API_URL=https://api.mpulse.bob4.fun
PUBLIC_WEB_URL=https://mpulse.bob4.fun
PUBLIC_ADMIN_URL=https://admin.mpulse.bob4.fun

BOOTSTRAP_ADMIN_USERNAME=mpulse-admin
BOOTSTRAP_ADMIN_PASSWORD=
