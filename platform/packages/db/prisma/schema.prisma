generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE
  CLIENT
  SERVICE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  nickname           String         @unique
  passwordHash       String
  locale             String         @default("ru")
  maxDevicesOverride Int?           @map("max_devices_override")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions Subscription[]
  devices      Device[]
  payments     Payment[]
  activationCodes ActivationCode[]
  minerCredentials MinerCredential[]
  clientLogs       ClientLog[]
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  passwordHash String
  role         AdminRole  @default(ADMIN)
  createdAt    DateTime   @default(now())
  auditLogs    AuditLog[]
}

model Plan {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  tier         Tier
  priceCents   Int
  currency     String         @default("RUB")
  durationDays Int
  maxDevices   Int            @default(1)
  active       Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  source    String             @default("manual")
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id])
  payments  Payment[]

  @@index([userId, status])
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  hwid        String
  os          String?
  osVersion   String?  @map("os_version")
  appVersion  String?  @map("app_version")
  appBuild    Int?     @map("app_build")
  label       String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hwid])
}

model ActivationCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String?
  amountCents    Int
  currency       String        @default("RUB")
  provider       String        @default("manual")
  providerRef    String?       @unique
  status         PaymentStatus @default(PENDING)
  note           String?
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
}

model AuditLog {
  id        String    @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String?
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model MinerCredential {
  id          String   @id @default(cuid())
  userId      String
  mac         String
  username    String
  passwordEnc String   @map("password_enc")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mac])
  @@index([userId])
}

model ClientLog {
  id          String   @id @default(cuid())
  userId      String
  hwid        String
  filename    String
  sizeBytes   Int      @map("size_bytes")
  storagePath String   @map("storage_path")
  appVersion  String?  @map("app_version")
  appBuild    Int?     @map("app_build")
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([hwid])
}
