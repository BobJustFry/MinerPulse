{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MinerPulse",
  "version": "1.0.0",
  "identifier": "com.minerpulse.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MinerPulse 1.0.0 (build 8)",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDRjAxMDM3OTM1OTJGMQpSV1R4a2pWNUF3SFBEUW5QblhyVDRzekMvdkV1TjRDUjA0dHFNQkVyTFlZVEFMZS9tZFQ0UWwybQo=",
      "endpoints": [
        "https://raw.githubusercontent.com/BobJustFry/MinerPulse/main/releases/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
